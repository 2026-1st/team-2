# Team 2 LoL surrender prediction project environment variables
# Copy this file to .env and fill in real values. Do NOT commit .env.

# -----------------------------------------------------------------------------
# Riot Developer API
# -----------------------------------------------------------------------------
# Required. Riot Developer Portal에서 발급받은 API key.
RIOT_API_KEY=RGAPI_your_riot_api_key_here

# KR server uses platform routing for League/Summoner APIs and regional routing
# for Match-V5 APIs.
RIOT_PLATFORM_ROUTING=kr
RIOT_REGIONAL_ROUTING=asia

# Default collection scope
RIOT_QUEUE_ID=420
RIOT_DEFAULT_TIER=EMERALD
RIOT_DEFAULT_DIVISION=I

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Required if uploading shared datasets to Supabase.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# -----------------------------------------------------------------------------
# Supabase direct database connection for schema creation
# -----------------------------------------------------------------------------
SUPABASE_DB_URL=postgresql://postgres:your_database_password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_DB_PASSWORD=your_supabase_database_password_here

# -----------------------------------------------------------------------------
# Local paths
# -----------------------------------------------------------------------------
RAW_DATA_DIR=data/raw/riot
INTERIM_DATA_DIR=data/interim/riot
PROCESSED_DATA_DIR=data/processed/riot
OUTPUT_DIR=outputs
FIGURE_DIR=reports/figures
MODEL_DIR=models
