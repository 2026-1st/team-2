*.pkl
*.pickle
*.joblib
*.h5
*.keras
*.pt
*.pth
*.onnx

# Local-only commit/PR handoff notes; not a submission artifact.
/docs/bumjun_seungbeom_commit_pr_package/

# Submission data uses processed/riot files. Verification JSON summaries stay local.
/data_2/verification/
/data_3/verification/
